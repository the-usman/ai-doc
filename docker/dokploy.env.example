# AI-Doc — Dokploy production environment (Option A: build from Git)
#
# Paste these into Dokploy → your app → Environment / Secrets.
# Replace every CHANGE_ME value. Do not commit real secrets to Git.
#
# Compose file: docker/docker-compose.prod.yml
# Dokploy builds the image on deploy (no external registry required).
#
# Dokploy UI: set Container / Application Port to 3000 (not host 3000).
# If deploy fails with "port 3000 already allocated", use expose-only compose (default)
# or set APP_HOST_PORT=3080 and uncomment ports in docker-compose.prod.yml.

# --- Image tag (built on server) ---
REGISTRY_IMAGE=ai-doc
IMAGE_TAG=latest

# Only if you uncomment ports in docker-compose.prod.yml (host 3000 already in use)
# APP_HOST_PORT=3080

# --- Application ---
APP_PORT=3000
APP_ENV=production
APP_SECRET=CHANGE_ME_min_32_char_random_string_for_sessions

# Public hostname only (no https://) — used by Traefik HTTPS router in compose
APP_DOMAIN=aidoc.usman.talent.techsupersonic.com
TRAEFIK_CERT_RESOLVER=letsencrypt

# Public URL — must match Dokploy domain (https when HTTPS is on)
FRONTEND_URL=https://aidoc.usman.talent.techsupersonic.com
API_URL=https://aidoc.usman.talent.techsupersonic.com

# --- PostgreSQL (service name "db" inside compose network) ---
DB_HOST=db
DB_PORT=5432
DB_NAME=ai_doc
DB_USER=ai_doc_user
DB_PASSWORD=CHANGE_ME_strong_db_password

# Use real values — do not use ${VAR} syntax here; Dokploy may not expand it
DATABASE_URL=postgresql://ai_doc_user:CHANGE_ME_strong_db_password@db:5432/ai_doc

# --- Redis (service name "redis") ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# --- OAuth (Google + GitHub — register both redirect URIs) ---
OAUTH_PROVIDER=google
GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=CHANGE_ME_google_client_secret
GOOGLE_REDIRECT_URI=https://aidoc.usman.talent.techsupersonic.com/api/auth/callback/google

GITHUB_CLIENT_ID=CHANGE_ME_github_oauth_client_id
GITHUB_CLIENT_SECRET=CHANGE_ME_github_oauth_client_secret
GITHUB_REDIRECT_URI=https://aidoc.usman.talent.techsupersonic.com/api/auth/callback/github

# --- Phase 2+ (optional in Phase 1) ---
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
