# AI-Doc — Environment Variables
#
# Copy this file to .env and fill in real values before running the project.
# This file is committed to version control — it is the map, not the territory.
# The .env file is in .gitignore and must never be committed.
#
# Every variable your application needs must be listed here.
# If you add a new variable, add it here in the same commit.

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_PORT=3000
APP_ENV=development          # development | production
APP_SECRET=replace_with_a_long_random_string_used_for_session_signing

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
DB_HOST=db                   # service name in docker-compose — not localhost
DB_PORT=5432
DB_NAME=ai-doc
DB_USER=ai-doc_user
DB_PASSWORD=replace_with_strong_password

# Full connection string (used by some ORM and migration tools)
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_HOST=redis             # service name in docker-compose
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}

# ---------------------------------------------------------------------------
# OAuth — Google
# Create credentials at: console.cloud.google.com → APIs & Services → Credentials
# Add authorised redirect URI: http://localhost:3000/auth/callback/google (local)
#                               https://your-domain.com/auth/callback/google (production)
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=replace_with_google_client_id
GOOGLE_CLIENT_SECRET=replace_with_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback/google

# ---------------------------------------------------------------------------
# OAuth — GitHub (alternative to Google)
# Create at: github.com → Settings → Developer settings → OAuth Apps
# ---------------------------------------------------------------------------
GITHUB_CLIENT_ID=replace_with_github_client_id
GITHUB_CLIENT_SECRET=replace_with_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:3000/auth/callback/github

# ---------------------------------------------------------------------------
# LLM API — Phase 2 onward
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=replace_with_anthropic_api_key
OPENAI_API_KEY=replace_with_openai_api_key_if_using_openai

# ---------------------------------------------------------------------------
# LangSmith — Phase 5 onward
# Create project at: smith.langchain.com
# ---------------------------------------------------------------------------
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=replace_with_langsmith_api_key
LANGCHAIN_PROJECT=ai-doc

# ---------------------------------------------------------------------------
# Production only — set in Dokploy secrets panel, not here
# ---------------------------------------------------------------------------
REGISTRY_IMAGE=replace_with_your_container_registry_image_path
IMAGE_TAG=latest
