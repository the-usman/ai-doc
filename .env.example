# AI-Doc — Environment Variables
# Copy to .env and fill in values. Never commit .env.

APP_PORT=3000
APP_ENV=development
APP_SECRET=replace_with_a_long_random_string_at_least_32_chars
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:8000

DB_HOST=db
DB_PORT=5432
DB_NAME=ai-doc
DB_USER=ai-doc_user
DB_PASSWORD=replace_with_strong_password
DATABASE_URL=postgresql://ai-doc_user:replace_with_strong_password@db:5432/ai-doc

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

GOOGLE_CLIENT_ID=replace_with_google_client_id
GOOGLE_CLIENT_SECRET=replace_with_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google

GITHUB_CLIENT_ID=replace_with_github_client_id
GITHUB_CLIENT_SECRET=replace_with_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:3000/api/auth/callback/github

# Default for GET /api/auth/login (legacy); sign-in UI uses both providers
OAUTH_PROVIDER=google

# Phase 2 — LangChain chat application
ANTHROPIC_API_KEY=replace_with_anthropic_api_key
CHAT_MODEL=claude-opus-4-8
CHAT_MAX_TOKENS=4096
# Retries for transient Anthropic errors (e.g. HTTP 529 "Overloaded")
ANTHROPIC_MAX_RETRIES=5
# Internal URL of the MCP server service (Phase 2, Step 7)
MCP_URL=http://mcp:8001

# Phase 3 — LangGraph agents
AGENTS_MODEL=claude-opus-4-8
AGENTS_MAX_TOKENS=2048
# Shared secret required on POST /api/agents/trigger (used by n8n). Leave blank
# to disable the trigger endpoint. Generate one, e.g.: openssl rand -base64 48
AGENTS_TRIGGER_TOKEN=replace_with_a_long_random_trigger_secret

# Phase 4 — Knowledge (RAG)
# OpenAI is used only for embeddings; the answer model stays Anthropic.
OPENAI_API_KEY=replace_with_openai_api_key
# Must match the VECTOR(1536) column in schema/schema.sql (see ADR-008).
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
# RecursiveCharacterTextSplitter parameters in tokens (see ADR-009).
CHUNK_SIZE=512
CHUNK_OVERLAP=64
# Chunks retrieved per question (see ADR-010).
RAG_TOP_K=5
# Redis-backed persistent conversation memory (see ADR-011).
REDIS_URL=redis://redis:6379
MEMORY_WINDOW_TURNS=10

REGISTRY_IMAGE=your-registry/ai-doc
IMAGE_TAG=latest


